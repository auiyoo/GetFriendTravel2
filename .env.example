# ==============================
# IT Dashboard Configuration
# ==============================
# Copy this file to .env and fill in your values

# Server
PORT=3000

# Splunk Connection (leave blank to use mock data)
SPLUNK_HOST=your-splunk-host.company.com
SPLUNK_PORT=8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=your-password
# OR use Bearer Token instead of username/password
SPLUNK_TOKEN=
# Use SSL (true/false)
SPLUNK_SSL=true

# Splunk Index settings
SPLUNK_INDEX=main
# Enable ITSI-specific queries (true if you have Splunk ITSI installed)
SPLUNK_ITSI=false

# Dashboard settings
# Data refresh interval in seconds
REFRESH_INTERVAL=60
# Organization name shown in header
ORG_NAME=TrustBank
# Dashboard title
DASHBOARD_TITLE=Executive Overview
